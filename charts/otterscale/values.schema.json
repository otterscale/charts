{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": {
        "imageRegistry": { "type": "string" },
        "imagePullSecrets": { "type": "array" },
        "storageClass": { "type": "string" }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "server": {
      "type": "object",
      "properties": {
        "externalURL": { "type": "string", "description": "Override server external URL for clients." },
        "externalTunnelURL": { "type": "string", "description": "Override server external tunnel URL for agents." },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          },
          "required": ["repository"]
        },
        "ports": {
          "type": "object",
          "properties": {
            "http": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "tunnel": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "annotations": { "type": "object" },
            "automountServiceAccountToken": { "type": "boolean" }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "annotations": { "type": "object" },
            "labels": { "type": "object" }
          }
        },
        "resources": { "type": "object" },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          }
        },
        "pdb": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" }
          }
        },
        "networkPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": { "type": "array" },
        "priorityClassName": { "type": "string" },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "env": { "type": "array" },
        "extraEnvFrom": { "type": "array" },
        "extraVolumes": { "type": "array" },
        "extraVolumeMounts": { "type": "array" },
        "extraContainers": { "type": "array" },
        "initContainers": { "type": "array" }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "externalURL": { "type": "string", "minLength": 1, "pattern": "^https?://", "description": "Base external URL (e.g. http://192.168.1.100). Required." },
        "replicaCount": { "type": "integer", "minimum": 0 },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
          },
          "required": ["repository"]
        },
        "ports": {
          "type": "object",
          "properties": {
            "http": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "serviceAccount": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" },
            "annotations": { "type": "object" },
            "automountServiceAccountToken": { "type": "boolean" }
          }
        },
        "service": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
            "annotations": { "type": "object" },
            "labels": { "type": "object" }
          }
        },
        "resources": { "type": "object" },
        "autoscaling": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 }
          }
        },
        "pdb": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" }
          }
        },
        "networkPolicy": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": { "type": "array" },
        "priorityClassName": { "type": "string" },
        "terminationGracePeriodSeconds": { "type": "integer", "minimum": 0 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "envoy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  },
  "required": ["dashboard"]
}
